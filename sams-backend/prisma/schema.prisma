// prisma/schema.prisma
// Maps 1-to-1 to atlas_sams_db — do NOT modify table/column names

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

// ─── users ───────────────────────────────────────────────────────────────────
model users {
  id         Int       @id @default(autoincrement())
  name       String    @db.VarChar(100)
  email      String    @unique @db.VarChar(100)
  password   String    @db.VarChar(255)
  role       users_role
  phone      String?   @db.VarChar(20)
  status     users_status @default(active)
  created_at DateTime  @default(now())
  updated_at DateTime  @updatedAt

  // Relations
  school_events        school_events[]
  teacher_subjects     teacher_subjects[]
  homework_assigned    homework[]         @relation("TeacherHomework")
  observations_received observations[]   @relation("ObservedTeacher")
  observations_given   observations[]    @relation("ObservedBy")
  performance_scores   performance_scores?
  leave_requests       leave_requests[]
  teacher_lo_entries   teacher_performance_lo[] @relation("TeacherPerformanceLO")

  @@index([role], name: "idx_user_role")
}

enum users_role {
  admin
  teacher
}

enum users_status {
  active
  inactive
}

// ─── classes ─────────────────────────────────────────────────────────────────
model classes {
  id         Int      @id @default(autoincrement())
  class_name String   @db.VarChar(50)
  section    String   @db.VarChar(10)
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  students         students[]
  teacher_subjects teacher_subjects[]
  syllabus         syllabus[]
  homework         homework[]
  teacher_lo       teacher_performance_lo[]

  @@unique([class_name, section])
}

// ─── subjects ────────────────────────────────────────────────────────────────
model subjects {
  id          Int      @id @default(autoincrement())
  name        String   @unique @db.VarChar(100)
  code        String?  @db.VarChar(20)
  description String?  @db.Text
  created_at  DateTime @default(now())
  updated_at  DateTime @updatedAt

  teacher_subjects      teacher_subjects[]
  syllabus              syllabus[]
  homework              homework[]
  learning_outcomes     learning_outcomes[]
  acad_class_subjects   acad_class_subjects[]
  teacher_lo            teacher_performance_lo[]
}

// ═══════════════════════════════════════════════════════════════════════════════
// ACADEMIC MANAGEMENT (standalone class/section/subject/stream structure)
// ═══════════════════════════════════════════════════════════════════════════════

// ─── academic_classes (standalone class entities) ────────────────────────────
model academic_classes {
  id             Int      @id @default(autoincrement())
  name           String   @db.VarChar(100)
  class_number   String   @db.VarChar(20)
  sort_order     Int      @default(0)
  class_category String   @default("primary") @db.VarChar(30)
  description    String?  @db.Text
  created_at     DateTime @default(now())
  updated_at     DateTime @updatedAt

  acad_class_sections  acad_class_sections[]
  acad_class_subjects  acad_class_subjects[]
  acad_class_streams   acad_class_streams[]

  @@unique([name])
}

// ─── sections (standalone section entities) ──────────────────────────────────
model sections {
  id          Int      @id @default(autoincrement())
  name        String   @db.VarChar(50)
  code        String   @db.VarChar(10)
  description String?  @db.Text
  created_at  DateTime @default(now())
  updated_at  DateTime @updatedAt

  acad_class_sections acad_class_sections[]

  @@unique([code])
}

// ─── streams (groups like Science/Commerce/Arts for higher secondary) ────────
model streams {
  id          Int      @id @default(autoincrement())
  name        String   @db.VarChar(100)
  code        String   @db.VarChar(20)
  description String?  @db.Text
  created_at  DateTime @default(now())
  updated_at  DateTime @updatedAt

  acad_class_sections  acad_class_sections[]
  acad_class_subjects  acad_class_subjects[]
  acad_class_streams   acad_class_streams[]

  @@unique([code])
}

// ─── acad_class_sections (assign sections to classes, optionally under a stream)
model acad_class_sections {
  id         Int      @id @default(autoincrement())
  class_id   Int
  section_id Int
  stream_id  Int?
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  class   academic_classes @relation(fields: [class_id],   references: [id], onDelete: Cascade)
  section sections         @relation(fields: [section_id], references: [id], onDelete: Cascade)
  stream  streams?         @relation(fields: [stream_id],  references: [id], onDelete: SetNull)

  @@unique([class_id, section_id, stream_id])
  @@index([class_id], name: "idx_acs_class")
}

// ─── acad_class_subjects (assign subjects to classes, optionally under a stream)
model acad_class_subjects {
  id         Int      @id @default(autoincrement())
  class_id   Int
  subject_id Int
  stream_id  Int?
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  class   academic_classes @relation(fields: [class_id],   references: [id], onDelete: Cascade)
  subject subjects         @relation(fields: [subject_id], references: [id], onDelete: Cascade)
  stream  streams?         @relation(fields: [stream_id],  references: [id], onDelete: SetNull)

  @@unique([class_id, subject_id, stream_id])
  @@index([class_id], name: "idx_acsub_class")
}

// ─── acad_class_streams (link streams/groups to classes) ─────────────────────
model acad_class_streams {
  id         Int      @id @default(autoincrement())
  class_id   Int
  stream_id  Int
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  class  academic_classes @relation(fields: [class_id],  references: [id], onDelete: Cascade)
  stream streams          @relation(fields: [stream_id], references: [id], onDelete: Cascade)

  @@unique([class_id, stream_id])
}

// ─── students ────────────────────────────────────────────────────────────────
model students {
  id         Int            @id @default(autoincrement())
  name       String         @db.VarChar(100)
  roll_no    String         @db.VarChar(20)
  email      String?        @db.VarChar(100)
  class_id   Int
  gender     students_gender?
  created_at DateTime       @default(now())
  updated_at DateTime       @updatedAt

  class                classes               @relation(fields: [class_id], references: [id], onDelete: Cascade)
  homework_submissions homework_submissions[]
  learning_outcomes    learning_outcomes[]

  @@unique([roll_no, class_id])
  @@index([class_id], name: "idx_student_class")
}

enum students_gender {
  Male
  Female
  Other
}

// ─── teacher_subjects ─────────────────────────────────────────────────────────
model teacher_subjects {
  id         Int      @id @default(autoincrement())
  teacher_id Int
  subject_id Int
  class_id   Int
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  teacher users    @relation(fields: [teacher_id], references: [id], onDelete: Cascade)
  subject subjects @relation(fields: [subject_id], references: [id], onDelete: Cascade)
  class   classes  @relation(fields: [class_id],   references: [id], onDelete: Cascade)

  @@unique([teacher_id, subject_id, class_id])
  @@index([teacher_id, subject_id, class_id], name: "idx_ts")
}

// ─── syllabus ────────────────────────────────────────────────────────────────
model syllabus {
  id             Int      @id @default(autoincrement())
  class_id       Int
  subject_id     Int
  chapter        String?  @db.VarChar(100)
  topic          String   @db.VarChar(255)
  planned_date   DateTime? @db.Date
  completed_date DateTime? @db.Date
  is_completed   Boolean  @default(false)
  created_at     DateTime @default(now())
  updated_at     DateTime @updatedAt

  class   classes  @relation(fields: [class_id],   references: [id], onDelete: Cascade)
  subject subjects @relation(fields: [subject_id], references: [id], onDelete: Cascade)

  @@index([class_id, subject_id], name: "idx_syllabus")
}

// ─── homework ─────────────────────────────────────────────────────────────────
model homework {
  id            Int      @id @default(autoincrement())
  teacher_id    Int
  class_id      Int
  subject_id    Int
  description   String   @db.Text
  assigned_date DateTime? @db.Date
  due_date      DateTime? @db.Date
  created_at    DateTime @default(now())
  updated_at    DateTime @updatedAt

  teacher     users                  @relation("TeacherHomework", fields: [teacher_id], references: [id], onDelete: Cascade)
  class       classes                @relation(fields: [class_id],   references: [id], onDelete: Cascade)
  subject     subjects               @relation(fields: [subject_id], references: [id], onDelete: Cascade)
  submissions homework_submissions[]

  @@index([class_id, subject_id, teacher_id], name: "idx_hw")
}

// ─── homework_submissions ─────────────────────────────────────────────────────
model homework_submissions {
  id              Int                       @id @default(autoincrement())
  homework_id     Int
  student_id      Int
  submission_date DateTime                  @default(now())
  status          homework_submissions_status @default(submitted)
  score           Int?
  created_at      DateTime @default(now())
  updated_at      DateTime @updatedAt

  homework homework  @relation(fields: [homework_id], references: [id], onDelete: Cascade)
  student  students  @relation(fields: [student_id],  references: [id], onDelete: Cascade)

  @@unique([homework_id, student_id])
}

enum homework_submissions_status {
  submitted
  pending
  late
}

// ─── learning_outcomes ────────────────────────────────────────────────────────
model learning_outcomes {
  id               Int                   @id @default(autoincrement())
  student_id       Int
  subject_id       Int
  topic            String?               @db.VarChar(255)
  teacher_score    Decimal?              @db.Decimal(5, 2)
  principal_score  Decimal?              @db.Decimal(5, 2)
  status           learning_outcomes_status @default(Meeting)
  created_at       DateTime @default(now())
  updated_at       DateTime @updatedAt

  student  students @relation(fields: [student_id], references: [id], onDelete: Cascade)
  subject  subjects @relation(fields: [subject_id], references: [id], onDelete: Cascade)

  @@index([student_id, subject_id], name: "idx_lo")
}

enum learning_outcomes_status {
  Approaching
  Meeting
  Exceeding
}

// ─── observations ─────────────────────────────────────────────────────────────
model observations {
  id               Int      @id @default(autoincrement())
  teacher_id       Int
  observed_by      Int
  observation_date DateTime? @db.Date
  total_score      Int?
  max_score        Int      @default(50)
  created_at       DateTime @default(now())
  updated_at       DateTime @updatedAt

  teacher  users @relation("ObservedTeacher", fields: [teacher_id], references: [id], onDelete: Cascade)
  observer users @relation("ObservedBy",      fields: [observed_by], references: [id], onDelete: Cascade)
}

// ─── performance_scores ───────────────────────────────────────────────────────
model performance_scores {
  id                      Int      @id @default(autoincrement())
  teacher_id              Int      @unique
  syllabus_completion_pct Decimal? @db.Decimal(5, 2)
  lo_avg_pct              Decimal? @db.Decimal(5, 2)
  observation_pct         Decimal? @db.Decimal(5, 2)
  other_score             Decimal? @db.Decimal(5, 2)
  overall_score           Decimal? @db.Decimal(5, 2)
  created_at              DateTime @default(now())
  updated_at              DateTime @updatedAt

  teacher users @relation(fields: [teacher_id], references: [id], onDelete: Cascade)
}

// ─── leave_requests ───────────────────────────────────────────────────────────
model leave_requests {
  id           Int                  @id @default(autoincrement())
  user_id      Int
  type         String?              @db.VarChar(50)
  from_date    DateTime?            @db.Date
  to_date      DateTime?            @db.Date
  reason       String?              @db.Text
  status       leave_requests_status @default(Pending)
  applied_date DateTime             @default(now())
  created_at   DateTime             @default(now())
  updated_at   DateTime             @updatedAt

  user users @relation(fields: [user_id], references: [id], onDelete: Cascade)
}

enum leave_requests_status {
  Pending
  Approved
  Rejected
}

// ═══════════════════════════════════════════════════════════════════════════════
// EVENT MANAGEMENT
// ═══════════════════════════════════════════════════════════════════════════════

model school_events {
  id           Int                @id @default(autoincrement())
  title        String             @db.VarChar(255)
  description  String?            @db.Text
  event_date   DateTime?          @db.Date
  location     String?            @db.VarChar(255)
  event_type   school_events_type @default(school)
  target_class String?            @db.VarChar(100)
  status       school_events_status @default(upcoming)
  created_by   Int?
  created_at   DateTime           @default(now())
  updated_at   DateTime           @updatedAt

  creator      users?             @relation(fields: [created_by], references: [id], onDelete: SetNull)
  participants event_participants[]
  winners      event_winners[]
}

enum school_events_type {
  class
  school
  annual_sports
}

enum school_events_status {
  upcoming
  ongoing
  completed
}

model event_participants {
  id            Int      @id @default(autoincrement())
  event_id      Int
  student_name  String   @db.VarChar(100)
  student_class String?  @db.VarChar(50)
  roll_no       String?  @db.VarChar(20)
  created_at    DateTime @default(now())

  event   school_events   @relation(fields: [event_id], references: [id], onDelete: Cascade)
  winners event_winners[]

  @@index([event_id], name: "idx_ep_event")
}

model event_winners {
  id             Int                    @id @default(autoincrement())
  event_id       Int
  participant_id Int
  position       event_winners_position
  remarks        String?                @db.Text
  created_at     DateTime               @default(now())

  event       school_events      @relation(fields: [event_id], references: [id], onDelete: Cascade)
  participant event_participants @relation(fields: [participant_id], references: [id], onDelete: Cascade)

  @@unique([event_id, position])
  @@index([event_id], name: "idx_ew_event")
}

enum event_winners_position {
  first
  second
  third
}

// ─── teacher_performance_lo ──────────────────────────────────────────────────
model teacher_performance_lo {
  id              Int      @id @default(autoincrement())
  teacher_id      Int
  class_id        Int
  subject_id      Int
  month           String   @db.VarChar(20)
  week            String   @db.VarChar(50)
  topic           String   @db.VarChar(255)
  teacher_score   Decimal? @db.Decimal(5, 2)
  principal_score Decimal? @db.Decimal(5, 2)
  status          teacher_lo_status @default(Meeting)
  remarks         String?  @db.Text
  created_at      DateTime @default(now())
  updated_at      DateTime @updatedAt

  teacher users    @relation("TeacherPerformanceLO", fields: [teacher_id], references: [id], onDelete: Cascade)
  class   classes  @relation(fields: [class_id], references: [id], onDelete: Cascade)
  subject subjects @relation(fields: [subject_id], references: [id], onDelete: Cascade)

  @@index([teacher_id, month], name: "idx_tlo_teacher_month")
}

enum teacher_lo_status {
  Approaching
  Meeting
  Exceeding
}
