# ─── Database ────────────────────────────────────────────────────────────────
# You can use DATABASE_URL (Prisma standard)
DATABASE_URL="mysql://root:your_password@localhost:3306/atlas_sams_db?connection_limit=5"

# OR you can use explicit connection parameters (Hostinger standard)
DB_HOST=127.0.0.1
DB_USER=root
DB_PASSWORD=your_password
DB_NAME=atlas_sams_db

# PRODUCTION (Hostinger/Render) — set this in Dashboard > Environment Variables
# Use connection_limit=3 to stay within free-tier DB connection limits
# DATABASE_URL="mysql://user:password@127.0.0.1:3306/your_db?connection_limit=3"

# ─── Connection Pool Limits ───────────────────────────────────────────────────
# Controls the mysql2 raw SQL pool size (mysqlDb.js)
# Local dev: 5  |  Production (Render free tier): 3
MYSQL_POOL_LIMIT=5

# ─── JWT ─────────────────────────────────────────────────────────────────────
JWT_SECRET="your_super_secret_jwt_key_change_this_in_production_min_32_chars"
JWT_EXPIRES_IN="7d"

# ─── Server ───────────────────────────────────────────────────────────────────
PORT=5000
# IMPORTANT: Always set to 'production' on Render/VPS — affects logging and Prisma behavior
NODE_ENV=development

# ─── CORS ─────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins
ALLOWED_ORIGINS="http://localhost:5173,http://localhost:3000"

# ─── Bcrypt ───────────────────────────────────────────────────────────────────
BCRYPT_ROUNDS=12
